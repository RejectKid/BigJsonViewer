<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:BigJsonViewer.App"
        mc:Ignorable="d"
        d:DesignWidth="1280"
        d:DesignHeight="800"
        x:Class="BigJsonViewer.App.MainWindow"
        x:CompileBindings="True"
        Width="1280"
        Height="800"
        MinWidth="900"
        MinHeight="560"
        Title="BigJsonViewer">
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <Border Grid.Row="0" Padding="14,10" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,190,240,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                <Button Grid.Column="0" Padding="18,8" Click="OpenFile" Content="Open JSON" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="FileNameText" FontWeight="SemiBold" Text="No file open" />
                    <TextBlock x:Name="FileDetailsText" FontSize="11" Foreground="{DynamicResource ThemeForegroundLowBrush}" Text="Open a UTF-8 JSON or JSON Lines file to begin." />
                </StackPanel>
                <ComboBox x:Name="RecentFilesBox" Grid.Column="2" PlaceholderText="Recent files" SelectionChanged="RecentFileSelected" />
                <TextBox x:Name="SearchBox" Grid.Column="3" PlaceholderText="Search UTF-8 text…" KeyDown="SearchBoxKeyDown" />
                <ComboBox x:Name="SearchModeBox" Grid.Column="4" SelectedIndex="0" MinWidth="120">
                    <ComboBoxItem Content="Anywhere" />
                    <ComboBoxItem Content="String values" />
                    <ComboBoxItem Content="Property names" />
                    <ComboBoxItem Content="Scalars / syntax" />
                </ComboBox>
                <CheckBox x:Name="SelectedSubtreeOnly" Grid.Column="5" VerticalAlignment="Center" Content="Selected subtree" />
                <Button Grid.Column="6" Click="StartSearch" Content="Search" />
                <Button Grid.Column="7" Click="CancelOperation" Content="Cancel" />
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="14,7">
            <ProgressBar x:Name="OperationProgress" Grid.Column="0" Height="4" Minimum="0" Maximum="1" Value="0" />
            <TextBlock x:Name="OperationText" Grid.Column="1" Margin="12,0,0,0" FontSize="11" Text="Ready" />
        </Grid>

        <Grid Grid.Row="2" ColumnDefinitions="5*,6*" Margin="14,0,14,10" ColumnSpacing="10">
            <Border Grid.Column="0" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" CornerRadius="5">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Margin="10,8" FontWeight="SemiBold" Text="Structure" />
                    <ListBox x:Name="TreeRows" Grid.Row="1" SelectionChanged="TreeSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="local:NodeRowViewModel">
                                <Grid Margin="{Binding Indent}" ColumnDefinitions="26,*">
                                    <Button Grid.Column="0"
                                            Width="23"
                                            Height="23"
                                            Padding="0"
                                            IsVisible="{Binding CanExpand}"
                                            Click="ToggleNode"
                                            Content="{Binding ToggleGlyph}" />
                                    <TextBlock Grid.Column="1"
                                               Margin="5,0,0,0"
                                               VerticalAlignment="Center"
                                               FontFamily="Consolas,Cascadia Mono,Monospace"
                                               TextTrimming="CharacterEllipsis"
                                               Text="{Binding DisplayText}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="1" CornerRadius="5">
                <TabControl x:Name="DetailTabs">
                    <TabItem Header="Pretty / Raw">
                        <TextBox x:Name="RawPreview"
                                 Margin="8"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas,Cascadia Mono,Monospace"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </TabItem>
                    <TabItem Header="Table sample">
                        <TextBox x:Name="TablePreview"
                                 Margin="8"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 FontFamily="Consolas,Cascadia Mono,Monospace"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Text="Select an array to see a bounded table sample." />
                    </TabItem>
                    <TabItem Header="Search results">
                        <Grid RowDefinitions="Auto,*">
                            <Grid Grid.Row="0" Margin="10,6" ColumnDefinitions="*,Auto,Auto">
                                <TextBlock x:Name="SearchSummary" VerticalAlignment="Center" Text="No search has run." />
                                <Button Grid.Column="1" Margin="4,0" Padding="10,3" Click="PreviousSearchPage" Content="Previous" />
                                <Button Grid.Column="2" Padding="10,3" Click="NextSearchPage" Content="Next" />
                            </Grid>
                            <ListBox x:Name="SearchRows" Grid.Row="1" SelectionChanged="SearchSelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="local:SearchRowViewModel">
                                        <TextBlock Margin="8,4"
                                                   FontFamily="Consolas,Cascadia Mono,Monospace"
                                                   TextTrimming="CharacterEllipsis"
                                                   Text="{Binding DisplayText}" />
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="3" Padding="14,7" BorderBrush="{DynamicResource ThemeBorderLowBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock x:Name="StatusText" FontSize="11" Text="Ready" />
                <Button Grid.Column="1" Margin="8,0" Padding="8,2" Click="CopyPointer" Content="Copy pointer" />
                <Button Grid.Column="2" Margin="0,0,12,0" Padding="8,2" Click="ExportSelection" Content="Export selection" />
                <TextBlock Grid.Column="3" FontSize="11" Foreground="{DynamicResource ThemeForegroundLowBrush}" Text="Bounded-memory mode · .NET 10 · Avalonia 12" />
            </Grid>
        </Border>
    </Grid>
</Window>
